@page
@model NorthwindApp.Pages.Employees.CreateModel
@{ ViewData["Title"] = "Add Employee"; }

<div class="page-header">
    <div class="d-flex justify-content-between align-items-center">
        <h1><i class="bi bi-person-plus-fill me-2"></i>Add Employee</h1>
        <a asp-page="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Back</a>
    </div>
</div>
<div class="px-4">
    <div class="card" style="max-width: 600px;">
        <div class="card-body">
            <form method="post">
                <div class="row g-3">
                    <div class="col-md-6"><label class="form-label fw-bold">First Name *</label><input asp-for="Employee.FirstName" class="form-control" required /></div>
                    <div class="col-md-6"><label class="form-label fw-bold">Last Name *</label><input asp-for="Employee.LastName" class="form-control" required /></div>
                    <div class="col-md-6"><label class="form-label">Title</label><input asp-for="Employee.Title" class="form-control" /></div>
                    <div class="col-md-6"><label class="form-label">Job Title</label><input asp-for="Employee.JobTitle" class="form-control" /></div>
                    <div class="col-12"><label class="form-label">Email</label><input asp-for="Employee.EmailAddress" type="email" class="form-control" /></div>
                    <div class="col-md-6"><label class="form-label">Primary Phone</label><input asp-for="Employee.PrimaryPhone" class="form-control" /></div>
                    <div class="col-md-6"><label class="form-label">Secondary Phone</label><input asp-for="Employee.SecondaryPhone" class="form-control" /></div>
                    <div class="col-12"><label class="form-label">Notes</label><textarea asp-for="Employee.Notes" class="form-control" rows="3"></textarea></div>
                    <div class="col-12"><button type="submit" class="btn btn-primary me-2">Save</button><a asp-page="Index" class="btn btn-outline-secondary">Cancel</a></div>
                </div>
            </form>
        </div>
    </div>
</div>
