@page
@model NorthwindApp.Pages.IndexModel
@{
    ViewData["Title"] = "Dashboard";
}

@if (Model.ErrorMessage != null)
{
    <div class="error-banner mx-4 mt-3">
        <div class="error-title"><i class="bi bi-exclamation-triangle-fill me-2"></i>Error Loading Data</div>
        <div class="error-detail">@Model.ErrorMessage</div>
        <div class="error-detail mt-1"><small>File: @Model.ErrorFile | Line: @Model.ErrorLine</small></div>
        @if (Model.ErrorMessage.Contains("Managed Identity") || Model.ErrorMessage.Contains("authentication") || Model.ErrorMessage.Contains("token"))
        {
            <div class="mt-2 p-2 bg-white text-dark rounded small">
                <strong>Fix:</strong> Ensure the App Service has the User-Assigned Managed Identity assigned and 
                <code>AZURE_CLIENT_ID</code> app setting is set to the MI client ID.
            </div>
        }
    </div>
}

@if (Model.IsUsingDummyData)
{
    <div class="warning-banner mx-4 mt-3">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>
        <strong>Demo Mode:</strong> Showing sample data because the database is unavailable.
    </div>
}

<div class="page-header">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h1><i class="bi bi-speedometer2 me-2"></i>Dashboard</h1>
            <small class="text-muted">Northwind Order Management System</small>
        </div>
        <div>
            <span class="badge bg-success">Azure Hosted</span>
        </div>
    </div>
</div>

<div class="px-4">
    <!-- Stats Row -->
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="stat-card" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
                <div class="stat-number">@Model.CustomerCount</div>
                <div class="stat-label"><i class="bi bi-people me-1"></i>Customers</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card" style="background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);">
                <div class="stat-number">@Model.OrderCount</div>
                <div class="stat-label"><i class="bi bi-cart3 me-1"></i>Orders</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card" style="background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);">
                <div class="stat-number">@Model.ProductCount</div>
                <div class="stat-label"><i class="bi bi-box me-1"></i>Products</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card" style="background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%);">
                <div class="stat-number">@Model.EmployeeCount</div>
                <div class="stat-label"><i class="bi bi-person-badge me-1"></i>Employees</div>
            </div>
        </div>
    </div>

    <!-- Recent Orders -->
    <div class="row g-3">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header p-3">
                    <i class="bi bi-clock-history me-2"></i>Recent Orders
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead>
                                <tr>
                                    <th class="px-3">Order #</th>
                                    <th>Customer</th>
                                    <th>Date</th>
                                    <th>Status</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var order in Model.RecentOrders)
                                {
                                    <tr>
                                        <td class="px-3 fw-bold">#@order.OrderID</td>
                                        <td>@order.CustomerName</td>
                                        <td>@order.OrderDate?.ToString("MMM dd, yyyy")</td>
                                        <td>
                                            <span class="badge @(order.StatusName == "Shipped" ? "bg-success" : order.StatusName == "New" ? "bg-primary" : "bg-secondary")">
                                                @(order.StatusName ?? "Unknown")
                                            </span>
                                        </td>
                                        <td><a asp-page="/Orders/Details" asp-route-id="@order.OrderID" class="btn btn-sm btn-outline-primary btn-action">View</a></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
                <div class="card-footer bg-transparent text-end p-2">
                    <a asp-page="/Orders/Index" class="btn btn-sm btn-link">View all orders →</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card">
                <div class="card-header p-3">
                    <i class="bi bi-graph-up me-2"></i>Quick Links
                </div>
                <div class="card-body">
                    <div class="d-grid gap-2">
                        <a asp-page="/Customers/Create" class="btn btn-outline-primary">
                            <i class="bi bi-person-plus me-2"></i>Add Customer
                        </a>
                        <a asp-page="/Orders/Create" class="btn btn-outline-success">
                            <i class="bi bi-cart-plus me-2"></i>New Order
                        </a>
                        <a asp-page="/Products/Create" class="btn btn-outline-info">
                            <i class="bi bi-box-seam me-2"></i>Add Product
                        </a>
                        <a asp-page="/Employees/Create" class="btn btn-outline-warning">
                            <i class="bi bi-person-plus-fill me-2"></i>Add Employee
                        </a>
                        <a asp-page="/Chat" class="btn btn-outline-secondary">
                            <i class="bi bi-chat-dots me-2"></i>AI Assistant
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
