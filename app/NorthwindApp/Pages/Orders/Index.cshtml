@page
@model NorthwindApp.Pages.Orders.IndexModel
@{
    ViewData["Title"] = "Orders";
}

@if (Model.ErrorMessage != null)
{
    <div class="error-banner mx-4 mt-3">
        <div class="error-title"><i class="bi bi-exclamation-triangle-fill me-2"></i>Error</div>
        <div class="error-detail">@Model.ErrorMessage</div>
        <div class="error-detail"><small>File: @Model.ErrorFile | Line: @Model.ErrorLine</small></div>
        @if (Model.ErrorMessage.Contains("Managed Identity") || Model.ErrorMessage.Contains("authentication"))
        {
            <div class="mt-2 p-2 bg-white text-dark rounded small"><strong>Fix:</strong> Ensure the App Service has the User-Assigned Managed Identity assigned and <code>AZURE_CLIENT_ID</code> app setting is set to the MI client ID.</div>
        }
    </div>
}
@if (Model.IsUsingDummyData)
{
    <div class="warning-banner mx-4 mt-3"><i class="bi bi-exclamation-triangle-fill me-2"></i><strong>Demo Mode:</strong> Showing sample data.</div>
}

<div class="page-header">
    <div class="d-flex justify-content-between align-items-center">
        <h1><i class="bi bi-cart3 me-2"></i>Orders</h1>
        <a asp-page="Create" class="btn btn-primary"><i class="bi bi-cart-plus me-2"></i>New Order</a>
    </div>
</div>

<div class="px-4">
    <div class="card">
        <div class="card-header p-3 d-flex align-items-center gap-2">
            <form method="get" class="d-flex gap-2">
                <select name="statusId" class="form-select" style="width: auto;" onchange="this.form.submit()">
                    <option value="">All Statuses</option>
                    @foreach (var status in Model.Statuses)
                    {
                        @if (Model.StatusFilter == status.StatusID)
                        {
                            <option value="@status.StatusID" selected>@status.StatusName</option>
                        }
                        else
                        {
                            <option value="@status.StatusID">@status.StatusName</option>
                        }
                    }
                </select>
                @if (Model.StatusFilter.HasValue)
                {
                    <a asp-page="Index" class="btn btn-outline-danger"><i class="bi bi-x"></i></a>
                }
            </form>
            <span class="ms-auto text-muted small">@Model.Orders.Count orders</span>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th class="px-3">Order #</th>
                            <th>Customer</th>
                            <th>Employee</th>
                            <th>Order Date</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var o in Model.Orders)
                        {
                            <tr>
                                <td class="px-3 fw-bold">#@o.OrderID</td>
                                <td>@o.CustomerName</td>
                                <td>@o.EmployeeName</td>
                                <td>@o.OrderDate?.ToString("MMM dd, yyyy")</td>
                                <td>
                                    @{
                                        var statusClass = o.StatusName switch {
                                            "Shipped" => "bg-success",
                                            "New" => "bg-primary",
                                            "Delivered" => "bg-info",
                                            "Cancelled" => "bg-danger",
                                            _ => "bg-secondary"
                                        };
                                    }
                                    <span class="badge @statusClass">@(o.StatusName ?? "Unknown")</span>
                                </td>
                                <td>
                                    <a asp-page="Details" asp-route-id="@o.OrderID" class="btn btn-sm btn-outline-info btn-action me-1"><i class="bi bi-eye"></i></a>
                                    <a asp-page="Edit" asp-route-id="@o.OrderID" class="btn btn-sm btn-outline-primary btn-action me-1"><i class="bi bi-pencil"></i></a>
                                    <button class="btn btn-sm btn-outline-danger btn-action" onclick="deleteOrder(@o.OrderID)"><i class="bi bi-trash"></i></button>
                                </td>
                            </tr>
                        }
                        @if (!Model.Orders.Any())
                        {
                            <tr><td colspan="6" class="text-center py-4 text-muted">No orders found.</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
async function deleteOrder(id) {
    if (!confirm('Delete this order?')) return;
    const response = await fetch('/api/orders/' + id, { method: 'DELETE' });
    if (response.ok) location.reload();
    else alert('Error deleting order.');
}
</script>
}
