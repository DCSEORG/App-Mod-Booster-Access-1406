@page
@model NorthwindApp.Pages.Orders.CreateModel
@{ ViewData["Title"] = "New Order"; }

<div class="page-header">
    <div class="d-flex justify-content-between align-items-center">
        <h1><i class="bi bi-cart-plus me-2"></i>New Order</h1>
        <a asp-page="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Back</a>
    </div>
</div>
<div class="px-4">
    <div class="card" style="max-width: 600px;">
        <div class="card-body">
            <form method="post">
                <div class="row g-3">
                    <div class="col-12">
                        <label class="form-label fw-bold">Customer *</label>
                        <select asp-for="Order.CustomerID" class="form-select" required>
                            <option value="">-- Select Customer --</option>
                            @foreach (var c in Model.Customers)
                            {
                                <option value="@c.CustomerID">@c.CustomerName</option>
                            }
                        </select>
                    </div>
                    <div class="col-12">
                        <label class="form-label">Employee</label>
                        <select asp-for="Order.EmployeeID" class="form-select">
                            <option value="">-- Select Employee --</option>
                            @foreach (var e in Model.Employees)
                            {
                                <option value="@e.EmployeeID">@e.FullNameFNLN</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Order Date</label>
                        <input asp-for="Order.OrderDate" type="date" class="form-control" value="@DateTime.Today.ToString("yyyy-MM-dd")" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Status</label>
                        <select asp-for="Order.StatusID" class="form-select">
                            <option value="">-- Status --</option>
                            @foreach (var s in Model.Statuses)
                            {
                                <option value="@s.StatusID">@s.StatusName</option>
                            }
                        </select>
                    </div>
                    <div class="col-12"><label class="form-label">Notes</label><textarea asp-for="Order.Notes" class="form-control" rows="3"></textarea></div>
                    <div class="col-12"><button type="submit" class="btn btn-primary me-2">Create Order</button><a asp-page="Index" class="btn btn-outline-secondary">Cancel</a></div>
                </div>
            </form>
        </div>
    </div>
</div>
