@page "{id:int}"
@model NorthwindApp.Pages.Orders.DetailsModel
@{
    ViewData["Title"] = $"Order #{Model.Order?.OrderID}";
}

<div class="page-header">
    <div class="d-flex justify-content-between align-items-center">
        <h1><i class="bi bi-receipt me-2"></i>Order #@Model.Order?.OrderID</h1>
        <div>
            <a asp-page="Edit" asp-route-id="@Model.Order?.OrderID" class="btn btn-primary me-2"><i class="bi bi-pencil me-1"></i>Edit</a>
            <a asp-page="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Back</a>
        </div>
    </div>
</div>

<div class="px-4">
    @if (Model.Order != null)
    {
        <div class="row g-3 mb-3">
            <div class="col-md-6">
                <div class="card">
                    <div class="card-header p-3">Order Details</div>
                    <div class="card-body">
                        <dl class="row mb-0">
                            <dt class="col-sm-5">Customer</dt><dd class="col-sm-7">@Model.Order.CustomerName</dd>
                            <dt class="col-sm-5">Employee</dt><dd class="col-sm-7">@Model.Order.EmployeeName</dd>
                            <dt class="col-sm-5">Order Date</dt><dd class="col-sm-7">@Model.Order.OrderDate?.ToString("MMM dd, yyyy")</dd>
                            <dt class="col-sm-5">Shipped Date</dt><dd class="col-sm-7">@(Model.Order.ShippedDate?.ToString("MMM dd, yyyy") ?? "-")</dd>
                            <dt class="col-sm-5">Paid Date</dt><dd class="col-sm-7">@(Model.Order.PaidDate?.ToString("MMM dd, yyyy") ?? "-")</dd>
                            <dt class="col-sm-5">Status</dt><dd class="col-sm-7"><span class="badge bg-primary">@Model.Order.StatusName</span></dd>
                            <dt class="col-sm-5">Notes</dt><dd class="col-sm-7">@(Model.Order.Notes ?? "-")</dd>
                        </dl>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card">
                    <div class="card-header p-3">Order Items</div>
                    <div class="card-body p-0">
                        <table class="table mb-0">
                            <thead><tr><th class="px-3">Product</th><th>Qty</th><th>Price</th><th>Total</th></tr></thead>
                            <tbody>
                                @foreach (var d in Model.OrderDetails)
                                {
                                    <tr>
                                        <td class="px-3">@d.ProductName</td>
                                        <td>@d.Quantity</td>
                                        <td>£@d.UnitPrice.ToString("N2")</td>
                                        <td>£@((d.Quantity * d.UnitPrice).ToString("N2"))</td>
                                    </tr>
                                }
                                @if (!Model.OrderDetails.Any())
                                {
                                    <tr><td colspan="4" class="text-center text-muted py-3">No items</td></tr>
                                }
                            </tbody>
                            @if (Model.OrderDetails.Any())
                            {
                                <tfoot>
                                    <tr class="fw-bold">
                                        <td colspan="3" class="text-end px-3">Total:</td>
                                        <td>£@Model.OrderDetails.Sum(d => d.Quantity * d.UnitPrice).ToString("N2")</td>
                                    </tr>
                                </tfoot>
                            }
                        </table>
                    </div>
                </div>
            </div>
        </div>
    }
</div>
