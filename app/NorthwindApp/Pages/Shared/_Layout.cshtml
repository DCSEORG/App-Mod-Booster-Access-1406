<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Northwind</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <style>
        body { background: #f0f2f5; }
        .sidebar { min-height: 100vh; background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%); }
        .sidebar .nav-link { color: rgba(255,255,255,0.7); padding: 0.75rem 1.25rem; border-radius: 8px; margin: 2px 8px; transition: all 0.2s; }
        .sidebar .nav-link:hover, .sidebar .nav-link.active { color: #fff; background: rgba(255,255,255,0.15); }
        .sidebar .nav-link i { width: 20px; margin-right: 8px; }
        .sidebar-brand { padding: 1.5rem 1.25rem; border-bottom: 1px solid rgba(255,255,255,0.1); }
        .sidebar-brand h5 { color: #fff; margin: 0; font-weight: 700; }
        .sidebar-brand small { color: rgba(255,255,255,0.5); font-size: 0.75rem; }
        .main-content { background: #f0f2f5; min-height: 100vh; }
        .page-header { background: #fff; padding: 1.5rem 2rem; border-bottom: 1px solid #e9ecef; margin-bottom: 1.5rem; }
        .page-header h1 { margin: 0; font-size: 1.5rem; font-weight: 600; color: #1a1a2e; }
        .card { border: none; border-radius: 12px; box-shadow: 0 2px 8px rgba(0,0,0,0.08); }
        .card-header { background: #fff; border-bottom: 1px solid #f0f2f5; border-radius: 12px 12px 0 0 !important; font-weight: 600; }
        .stat-card { border-radius: 12px; padding: 1.5rem; color: #fff; }
        .stat-card .stat-number { font-size: 2.5rem; font-weight: 700; }
        .stat-card .stat-label { opacity: 0.85; font-size: 0.875rem; }
        .table th { background: #f8f9fa; font-weight: 600; font-size: 0.875rem; text-transform: uppercase; letter-spacing: 0.5px; color: #6c757d; }
        .btn-action { padding: 0.25rem 0.6rem; font-size: 0.8rem; }
        .error-banner { background: #dc3545; color: #fff; padding: 1rem 1.5rem; margin-bottom: 1rem; border-radius: 8px; }
        .error-banner .error-title { font-weight: 700; font-size: 1rem; }
        .error-banner .error-detail { font-size: 0.875rem; opacity: 0.9; }
        .warning-banner { background: #ffc107; color: #212529; padding: 0.75rem 1.5rem; margin-bottom: 1rem; border-radius: 8px; }
        .chat-container { height: calc(100vh - 250px); display: flex; flex-direction: column; }
        .chat-messages { flex: 1; overflow-y: auto; padding: 1rem; background: #f8f9fa; border-radius: 8px; }
        .chat-bubble { max-width: 80%; padding: 0.75rem 1rem; border-radius: 12px; margin-bottom: 0.75rem; }
        .chat-bubble.user { background: #0f3460; color: #fff; margin-left: auto; border-bottom-right-radius: 4px; }
        .chat-bubble.assistant { background: #fff; border: 1px solid #e9ecef; border-bottom-left-radius: 4px; }
    </style>
</head>
<body>
    <div class="d-flex">
        <!-- Sidebar -->
        <div class="sidebar d-flex flex-column" style="width: 260px; position: fixed; top: 0; left: 0; height: 100vh; z-index: 100; overflow-y: auto;">
            <div class="sidebar-brand">
                <h5><i class="bi bi-box-seam me-2"></i>Northwind</h5>
                <small>Order Management System</small>
            </div>
            <nav class="mt-3 flex-grow-1">
                <ul class="nav flex-column">
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString() == "/Index" ? "active" : "")" asp-page="/Index">
                            <i class="bi bi-speedometer2"></i> Dashboard
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString()?.StartsWith("/Customers") == true ? "active" : "")" asp-page="/Customers/Index">
                            <i class="bi bi-people"></i> Customers
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString()?.StartsWith("/Orders") == true ? "active" : "")" asp-page="/Orders/Index">
                            <i class="bi bi-cart3"></i> Orders
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString()?.StartsWith("/Products") == true ? "active" : "")" asp-page="/Products/Index">
                            <i class="bi bi-box"></i> Products
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString()?.StartsWith("/Employees") == true ? "active" : "")" asp-page="/Employees/Index">
                            <i class="bi bi-person-badge"></i> Employees
                        </a>
                    </li>
                    <li class="nav-item mt-3">
                        <a class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString() == "/Chat" ? "active" : "")" asp-page="/Chat">
                            <i class="bi bi-chat-dots"></i> AI Chat
                        </a>
                    </li>
                </ul>
            </nav>
            <div class="p-3 border-top" style="border-color: rgba(255,255,255,0.1) !important;">
                <a href="/swagger" target="_blank" class="nav-link" style="color: rgba(255,255,255,0.5); font-size: 0.8rem;">
                    <i class="bi bi-code-square"></i> API Docs
                </a>
            </div>
        </div>

        <!-- Main Content -->
        <div class="main-content flex-grow-1" style="margin-left: 260px;">
            @RenderBody()
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
