@page
@model ExpenseApp.Pages.Users.CreateUserModel
@{
    ViewData["Title"] = "Add User";
    ViewData["ErrorMessage"] = Model.ErrorMessage;
}

<div class="card-header" style="margin-bottom:20px">
    <h1 style="font-size:1.5rem;font-weight:600">Add User</h1>
    <a href="/Users" class="btn btn-secondary">← Back to Users</a>
</div>

<div class="card" style="max-width:500px">
    <form method="post">
        <div class="form-group">
            <label>Full Name</label>
            <input asp-for="Input.UserName" placeholder="e.g. Jane Smith" required />
        </div>
        <div class="form-group">
            <label>Email</label>
            <input asp-for="Input.Email" type="email" placeholder="jane@example.co.uk" required />
        </div>
        <div class="form-group">
            <label>Role</label>
            <select asp-for="Input.RoleId" required>
                <option value="">Select role…</option>
                @foreach (var r in Model.Roles)
                {
                    <option value="@r.RoleId">@r.RoleName</option>
                }
            </select>
        </div>
        <div class="form-group">
            <label>Manager (optional)</label>
            <select asp-for="Input.ManagerId">
                <option value="">No manager</option>
                @foreach (var u in Model.Managers)
                {
                    <option value="@u.UserId">@u.UserName</option>
                }
            </select>
        </div>
        <div style="display:flex;gap:12px;margin-top:8px">
            <button type="submit" class="btn btn-primary">Create User</button>
            <a href="/Users" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</div>
