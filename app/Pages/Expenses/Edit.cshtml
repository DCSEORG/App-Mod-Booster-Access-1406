@page
@model ExpenseApp.Pages.Expenses.EditModel
@{
    ViewData["Title"] = $"Edit Expense #{Model.ExpenseId}";
    ViewData["ErrorMessage"] = Model.ErrorMessage;
}

<div class="card-header" style="margin-bottom:20px">
    <h1 style="font-size:1.5rem;font-weight:600">Edit Expense #@Model.ExpenseId</h1>
    <a href="/Expenses/Detail?id=@Model.ExpenseId" class="btn btn-secondary">← Back</a>
</div>

<div class="card" style="max-width:600px">
    <form method="post">
        <input type="hidden" asp-for="ExpenseId" />
        <div class="form-group">
            <label>Category</label>
            <select asp-for="Input.CategoryId" required>
                @foreach (var c in Model.Categories)
                {
                    <option value="@c.CategoryId">@c.CategoryName</option>
                }
            </select>
        </div>
        <div class="form-group">
            <label>Amount (£)</label>
            <input asp-for="Input.AmountGBP" type="number" step="0.01" min="0.01" required />
        </div>
        <div class="form-group">
            <label>Expense Date</label>
            <input asp-for="Input.ExpenseDate" type="date" required />
        </div>
        <div class="form-group">
            <label>Description</label>
            <textarea asp-for="Input.Description" rows="3"></textarea>
        </div>
        <div style="display:flex;gap:12px;margin-top:8px">
            <button type="submit" class="btn btn-primary">Save Changes</button>
            <a href="/Expenses/Detail?id=@Model.ExpenseId" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</div>
