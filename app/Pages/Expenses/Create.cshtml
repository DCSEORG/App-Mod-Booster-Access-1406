@page
@model ExpenseApp.Pages.Expenses.CreateModel
@{
    ViewData["Title"] = "New Expense";
    ViewData["ErrorMessage"] = Model.ErrorMessage;
}

<div class="card-header" style="margin-bottom:20px">
    <h1 style="font-size:1.5rem;font-weight:600">New Expense</h1>
    <a href="/Expenses" class="btn btn-secondary">← Back to Expenses</a>
</div>

<div class="card" style="max-width:600px">
    <form method="post">
        <div class="form-group">
            <label>Employee</label>
            <select asp-for="Input.UserId" required>
                <option value="">Select employee…</option>
                @foreach (var u in Model.Users)
                {
                    <option value="@u.UserId">@u.UserName (@u.RoleName)</option>
                }
            </select>
        </div>
        <div class="form-group">
            <label>Category</label>
            <select asp-for="Input.CategoryId" required>
                <option value="">Select category…</option>
                @foreach (var c in Model.Categories)
                {
                    <option value="@c.CategoryId">@c.CategoryName</option>
                }
            </select>
        </div>
        <div class="form-group">
            <label>Amount (£)</label>
            <input asp-for="Input.AmountGBP" type="number" step="0.01" min="0.01" placeholder="0.00" required />
        </div>
        <div class="form-group">
            <label>Expense Date</label>
            <input asp-for="Input.ExpenseDate" type="date" required />
        </div>
        <div class="form-group">
            <label>Description</label>
            <textarea asp-for="Input.Description" rows="3" placeholder="What was the expense for?"></textarea>
        </div>
        <div style="display:flex;gap:12px;margin-top:8px">
            <button type="submit" class="btn btn-primary">Save as Draft</button>
            <a href="/Expenses" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</div>
